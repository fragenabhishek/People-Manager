# Copy this file to .env and fill in your values
# Generate a secret key: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=
FLASK_DEBUG=True
PORT=5000

# Database — priority: DATABASE_URL > MONGO_URI > local JSON files
# PostgreSQL (recommended for production)
DATABASE_URL=
# Example: DATABASE_URL=postgresql://user:pass@localhost:5432/people_manager

# MongoDB Atlas (legacy, leave empty to skip)
MONGO_URI=

# JWT token lifetimes (optional, defaults shown)
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_MINUTES=10080

# Google Gemini AI (leave empty to disable AI features)
GEMINI_API_KEY=
